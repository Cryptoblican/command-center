{
  "name": "command-center",
  "version": "0.1.0",
  "description": "Unified Command Center Dashboard - Email, Calendar, Projects, Automation, Predictions",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "server": "node server.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm install --include=dev && npm run build",
    "start": "node server.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["dashboard", "email", "calendar", "automation"],
  "author": "Brett Nielsen",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.6",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.1"
  }
}
